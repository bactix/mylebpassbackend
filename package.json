{
  "name": "mylebpass-backend",
  "version": "1.0.0",
  "description": "MyLebPass Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only api/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --watch",
    "test:ci": "jest --coverage",
    "lint": "eslint api --ext .ts",
    "lint:fix": "eslint api --ext .ts --fix",
    "format": "prettier --write \"api/**/*.ts\""
  },
  "keywords": [
    "express",
    "nodejs"
  ],
  "author": "Mohammed Haydar",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "mongoose": "^9.6.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}

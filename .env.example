# ----------------------------------------------------------------------------
# Backend environment variables
# Copy to `.env` for local dev. On Railway, set these in the service Variables.
# ----------------------------------------------------------------------------

# Runtime environment: development | production
NODE_ENV=development

# Port the server listens on.
# Local dev only — on Railway leave this UNSET; Railway injects PORT
# automatically and the app falls back to it (process.env.PORT || 3000).
PORT=4000

# Log verbosity: error | warn | info | debug
LOG_LEVEL=debug

# MongoDB connection string.
# - Local dev: connect to a local Mongo or use the PUBLIC Railway proxy URL.
# - Railway:   reference the MongoDB service, e.g. ${{MongoDB.MONGO_URL}}
#              (prefer the internal mongodb.railway.internal host).
# If left empty, the API runs in offline mode (no database).
MONGO_URL=mongodb://localhost:27017/mylebpass

# Secret used to sign/verify JWTs. MUST be a long random string in production.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

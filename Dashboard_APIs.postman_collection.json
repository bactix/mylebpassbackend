  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('userToken', jsonData.data.token);",
                  "  pm.environment.set('userId', jsonData.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/auth",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "auth"]
            }
          }
        }
      ]
    },

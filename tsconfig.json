{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./api",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "include": ["api/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "api/routes/app/userRoutes.ts",
    "api/controllers/app/userController.ts",
    "api/services/app/userService.ts"
  ]
}
